#cycling route picker
import tkinter as tk
import random as r
root = tk.Tk()
root.geometry("1920x1080")
root.title("cycling")
n = 0
 
def on_click():
    #define random function, V1.0
    routes = ["intervals at WCH", "Mt Faber 3 laps", "Mt Faber single + coffee base", "Changi village", "Marina Bay Loop from JE", "Bedok Jetty", "Changi Airport", "ECP Length"]
    resultantforce = r.choice(routes)
    label = tk.Label(root, text=(resultantforce), font =("Arial,1000"))
    label.pack(pady=20)
    n = n+1
def click_on():
    #define zone picker button function V2.0 update(10/7)
        global zones
        global appliedforce
        zones = ["Active Recovery(Z1)", "Endurance(Z2)", "Tempo(Z3)", "Sub Threshold(Z4)", "Anaerobic Zone(Z5)"]
        appliedforce = r.choice(zones)
        label = tk.Label(root, text=(appliedforce), font =("Arial,1000"))
        label.pack(pady=60) 

if n >= 0:
      #ver 2 update 10/7
      button = tk.Button(root, text="Click for route", command=on_click)
      button.pack(pady=20)

button = tk.Button(root, text="Click for zone", command=click_on)
button.pack(pady=60)

root.mainloop()
 
